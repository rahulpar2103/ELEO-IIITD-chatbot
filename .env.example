# ==============================================================================
# ELEO Backend Environment Configuration Example
# Copy this file to .env and configure the values for your environment.
# ==============================================================================

# Gemini API configuration
GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_MODEL=models/gemini-embedding-2
LLM_MODEL=gemini-flash-lite-latest

# GitHub content synchronization configuration (required for production)
# Leave GITHUB_TOKEN empty to use local filesystem storage (local development fallback)
GITHUB_TOKEN=
GITHUB_REPO_OWNER=rahulpar2103
GITHUB_REPO_NAME=ELEO-IIITD-chatbot
GITHUB_BRANCH=master
GITHUB_DATA_DIR_PATH=data/content
